{
  "info": {
    "name": "HealthCareGov MVP API",
    "description": "Complete Postman collection for the HealthCareGov Public Healthcare & Hospital Management System.\n\n## How to use\n1. Import this collection into Postman\n2. Set the collection variable `base_url` to `http://localhost:9090`\n3. Run requests in the order shown — start with '00 Setup' folder\n4. After login, the token is auto-saved to `{{jwt_token}}` via the test script\n5. All authenticated requests automatically use `{{jwt_token}}`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",    "value": "http://localhost:9090", "type": "string" },
    { "key": "jwt_token",   "value": "",                       "type": "string" },
    { "key": "admin_token", "value": "",                       "type": "string" },
    { "key": "doctor_token","value": "",                       "type": "string" },
    { "key": "patient_token","value": "",                      "type": "string" }
  ],
  "item": [

    {
      "name": "00 · Setup (Run First)",
      "description": "Register all users, approve them, then login. Run these in order on a fresh database.",
      "item": [
        {
          "name": "1. Register Admin",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('admin_id', pm.response.json().userID); }"], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/users/register"},
            "body": {"mode": "raw", "raw": "{\n  \"name\":     \"System Admin\",\n  \"role\":     \"Admin\",\n  \"email\":    \"admin@hcg.com\",\n  \"phone\":    \"9000000001\",\n  \"password\": \"admin123\"\n}"}
          }
        },
        {
          "name": "2. Register Doctor",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('doctor_id', pm.response.json().userID); }"], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/users/register"},
            "body": {"mode": "raw", "raw": "{\n  \"name\":     \"Dr. Priya Sharma\",\n  \"role\":     \"Doctor\",\n  \"email\":    \"doctor@hcg.com\",\n  \"phone\":    \"9000000002\",\n  \"password\": \"doc123\"\n}"}
          }
        },
        {
          "name": "3. Register Compliance Officer",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('compliance_id', pm.response.json().userID); }"], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/users/register"},
            "body": {"mode": "raw", "raw": "{\n  \"name\":     \"Compliance Officer\",\n  \"role\":     \"Compliance\",\n  \"email\":    \"comp@hcg.com\",\n  \"phone\":    \"9000000003\",\n  \"password\": \"comp123\"\n}"}
          }
        },
        {
          "name": "4. Register Auditor",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('auditor_id', pm.response.json().userID); }"], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/users/register"},
            "body": {"mode": "raw", "raw": "{\n  \"name\":     \"Government Auditor\",\n  \"role\":     \"Auditor\",\n  \"email\":    \"audit@hcg.com\",\n  \"phone\":    \"9000000004\",\n  \"password\": \"aud123\"\n}"}
          }
        },
        {
          "name": "5. Register Program Manager",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('manager_id', pm.response.json().userID); }"], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/users/register"},
            "body": {"mode": "raw", "raw": "{\n  \"name\":     \"Program Manager\",\n  \"role\":     \"Manager\",\n  \"email\":    \"manager@hcg.com\",\n  \"phone\":    \"9000000005\",\n  \"password\": \"mgr123\"\n}"}
          }
        },
        {
          "name": "6. Register Patient",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('patient_id', pm.response.json().patientID); pm.collectionVariables.set('patient_user_id', pm.response.json().userID); }"], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/patients/register"},
            "body": {"mode": "raw", "raw": "{\n  \"name\":        \"Ravi Kumar\",\n  \"dob\":         \"1990-05-15\",\n  \"gender\":      \"Male\",\n  \"address\":     \"42 Gandhi Nagar, Chennai\",\n  \"contactInfo\": \"9876543210\",\n  \"email\":       \"patient@hcg.com\",\n  \"password\":    \"pat123\"\n}"}
          }
        },
        {
          "name": "7. Admin Login (saves token)",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) { var r = pm.response.json(); pm.collectionVariables.set('jwt_token', r.token); pm.collectionVariables.set('admin_token', r.token); console.log('Admin token saved'); }"], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/users/login"},
            "body": {"mode": "raw", "raw": "{\n  \"email\":    \"admin@hcg.com\",\n  \"password\": \"admin123\"\n}"}
          }
        },
        {
          "name": "8. Approve Doctor",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{admin_token}}"}],
            "url": {"raw": "{{base_url}}/api/users/{{doctor_id}}/status?adminId=1"},
            "body": {"mode": "raw", "raw": "{\n  \"status\": \"Active\"\n}"}
          }
        },
        {
          "name": "9. Approve Compliance Officer",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{admin_token}}"}],
            "url": {"raw": "{{base_url}}/api/users/{{compliance_id}}/status?adminId=1"},
            "body": {"mode": "raw", "raw": "{\n  \"status\": \"Active\"\n}"}
          }
        },
        {
          "name": "10. Approve Auditor",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{admin_token}}"}],
            "url": {"raw": "{{base_url}}/api/users/{{auditor_id}}/status?adminId=1"},
            "body": {"mode": "raw", "raw": "{\n  \"status\": \"Active\"\n}"}
          }
        },
        {
          "name": "11. Approve Program Manager",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{admin_token}}"}],
            "url": {"raw": "{{base_url}}/api/users/{{manager_id}}/status?adminId=1"},
            "body": {"mode": "raw", "raw": "{\n  \"status\": \"Active\"\n}"}
          }
        },
        {
          "name": "12. Approve Patient",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{admin_token}}"}],
            "url": {"raw": "{{base_url}}/api/users/{{patient_user_id}}/status?adminId=1"},
            "body": {"mode": "raw", "raw": "{\n  \"status\": \"Active\"\n}"}
          }
        },
        {
          "name": "13. Doctor Login (saves token)",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) { pm.collectionVariables.set('doctor_token', pm.response.json().token); }"], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/users/login"},
            "body": {"mode": "raw", "raw": "{\n  \"email\":    \"doctor@hcg.com\",\n  \"password\": \"doc123\"\n}"}
          }
        },
        {
          "name": "14. Patient Login (saves token)",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) { var r = pm.response.json(); pm.collectionVariables.set('patient_token', r.token); pm.collectionVariables.set('patient_id', r.patientID); }"], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/users/login"},
            "body": {"mode": "raw", "raw": "{\n  \"email\":    \"patient@hcg.com\",\n  \"password\": \"pat123\"\n}"}
          }
        }
      ]
    },

    {
      "name": "01 · User Management",
      "item": [
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}],
            "url": {"raw": "{{base_url}}/api/users"}
          }
        },
        {
          "name": "List Pending Users",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}],
            "url": {"raw": "{{base_url}}/api/users?status=Pending"}
          }
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{admin_token}}"}],
            "url": {"raw": "{{base_url}}/api/users/{{doctor_id}}/status?adminId=1"},
            "body": {"mode": "raw", "raw": "{\n  \"status\": \"Inactive\"\n}"}
          }
        },
        {
          "name": "Reactivate User",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{admin_token}}"}],
            "url": {"raw": "{{base_url}}/api/users/{{doctor_id}}/status?adminId=1"},
            "body": {"mode": "raw", "raw": "{\n  \"status\": \"Active\"\n}"}
          }
        },
        {
          "name": "Reject User",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{admin_token}}"}],
            "url": {"raw": "{{base_url}}/api/users/99/status?adminId=1"},
            "body": {"mode": "raw", "raw": "{\n  \"status\": \"Rejected\"\n}"}
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}],
            "url": {"raw": "{{base_url}}/api/users/logout/1"}
          }
        },
        {
          "name": "[Security] 401 - No Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{base_url}}/api/users"},
            "description": "Expected: 401 Unauthorized"
          }
        },
        {
          "name": "[Security] 403 - Wrong Role (Doctor tries admin endpoint)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{doctor_token}}"}],
            "url": {"raw": "{{base_url}}/api/users"},
            "description": "Expected: 403 Forbidden"
          }
        }
      ]
    },

